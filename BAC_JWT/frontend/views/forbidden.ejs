<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>403 - BAC JWT Lab</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <div class="container">
    <h1>403 Forbidden</h1>
    <p>Sorry <strong><%= user.username %></strong>, only admins can view this page.</p>
    <p>Your current role: <code><%= user.role %></code></p>
    <p><a href="/dashboard">Back to dashboard</a></p>
  </div>
</body>
</html>
